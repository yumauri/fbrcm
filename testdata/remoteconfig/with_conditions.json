{
  "conditions": [
    {
      "name": "android",
      "expression": "device.os == 'android'",
      "tagColor": "BLUE"
    },
    {
      "name": "ios",
      "expression": "device.os == 'ios'",
      "tagColor": "INDIGO"
    }
  ],
  "parameters": {
    "feature_login": {
      "defaultValue": {
        "value": "off"
      },
      "conditionalValues": {
        "android": {
          "value": "on"
        },
        "ios": {
          "value": "on"
        }
      },
      "description": "Login feature toggle",
      "valueType": "STRING"
    }
  },
  "version": {
    "versionNumber": "3"
  }
}
