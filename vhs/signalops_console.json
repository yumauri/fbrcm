{
  "conditions": [
    {
      "name": "enterprise_accounts",
      "expression": "percent <= 10",
      "tagColor": "BLUE"
    },
    {
      "name": "incident_mode",
      "expression": "percent <= 5",
      "tagColor": "DEEP_ORANGE"
    },
    {
      "name": "eu_region",
      "expression": "device.country in ['de','fr','nl','se','ie']",
      "tagColor": "GREEN"
    },
    {
      "name": "new_dashboard_rollout_20",
      "expression": "percent <= 20",
      "tagColor": "PURPLE"
    },
    {
      "name": "admins",
      "expression": "percent <= 3",
      "tagColor": "ORANGE"
    }
  ],
  "parameters": {},
  "parameterGroups": {
    "navigation": {
